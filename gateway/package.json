{
  "name": "gateway",
  "version": "1.0.0",
  "private": true,
  "description": "API Gateway and AI orchestration layer for the AI platform.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "node --test -r ts-node/register src/__tests__/gateway.integration.test.ts",
    "start": "node dist/index.js",
    "worker:crm": "ts-node-dev --respawn --transpile-only src/examples/crm.consumer.ts",
    "worker:onboarding": "ts-node-dev --respawn --transpile-only src/examples/onboarding.consumer.ts",
    "worker:data-room": "ts-node-dev --respawn --transpile-only src/examples/dataRoom.consumer.ts",
    "mock:services": "ts-node-dev --respawn --transpile-only src/examples/mockServices.ts"
  },
  "dependencies": {
    "@ai-platform/events": "file:../packages/events",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
